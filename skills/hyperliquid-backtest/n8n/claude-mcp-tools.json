          "values": [
            {
              "name": "coin",
              "description": "Symbol, e.g. BTC, ETH, SOL",
              "type": "string"
            },
            {
              "name": "interval",
              "description": "Candle interval: 5m, 15m, 1h, 4h, or 1d",
              "type": "string"
            },
            {
              "name": "startTime",
              "description": "Range start, milliseconds since epoch",
              "type": "number"
            },
            {
              "name": "endTime",
              "description": "Range end, milliseconds since epoch",
              "type": "number"
            }
          ]
