{
  "name": "Send Email via SMTP",
  "nodes": [
    {
      "parameters": {
        "inputSource": "workflowInputs",
        "workflowInputs": {
          "values": [
            {
              "name": "to",
              "type": "string"
            },
            {
              "name": "subject",
              "type": "string"
            },
            {
              "name": "body",
              "type": "string"
            }
          ]
        }
      },
      "id": "24487811-103f-4bf1-8396-c29b07f672cb",
      "name": "When Executed by Another Workflow",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1.1,
      "position": [
        300,
        300
      ]
    },
    {
      "parameters": {
        "fromEmail": "REPLACE_WITH_YOUR_SMTP_FROM_ADDRESS@example.com",
        "toEmail": "={{ $json.to }}",
        "subject": "={{ $json.subject }}",
        "emailFormat": "text",
        "text": "={{ $json.body }}",
        "options": {}
      },
      "id": "b25c0f91-1841-48a6-8629-7472a64806aa",
      "name": "Send Email",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [
        560,
        300
      ],
      "credentials": {
        "smtp": {
          "id": "",
          "name": "SELECT_YOUR_SMTP_CREDENTIAL_HERE"
        }
      }
    }
  ],
  "connections": {
    "When Executed by Another Workflow": {
      "main": [
        [
          {
            "node": "Send Email",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "pinData": {}
}