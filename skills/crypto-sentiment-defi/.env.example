# X/Twitter session cookies, reused from the same account ClawdBot used.
# Test with `bird search Bitcoin --auth-token ... --ct0 ...` before relying on this daily —
# cookies can be IP/device-bound and may not transfer cleanly to a new machine.
X_AUTH_TOKEN=
X_CT0=

# Airtable — table IDs are fixed in airtable_sync.py, not secret
AIRTABLE_API_KEY=

# Model backend for sentiment refinement / social drafts
MOONSHOT_API_KEY=
OPENROUTER_API_KEY=
MODEL_BACKEND=moonshot
